# Test environment configuration
# Used when running e2e tests against the test database
# Uses different ports from dev so both can run simultaneously

# UI port (different from dev's 5174)
KHEF_UI_PORT=5176

# Point to test proxy server
KHEF_API_URL=http://localhost:5177/api

# Proxy forwards to test backend on port 3202 (isolated from dev API on 3201)
KHEF_PROXY_PORT=5177
KHEF_PROXY_TARGET=http://localhost:3202/api
KHEF_PROXY_LOG=../../logs/ui/api-errors-test.log
