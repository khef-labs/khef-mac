# Khef UI environment example

# Dev server port for `npm run dev` (Vite). The UI will listen on this port.
KHEF_UI_PORT=5174
# Alternative variable names also supported:
# VITE_PORT=5174
# PORT=5174 

# API base URL for the UI to call.
# Point this at the proxy server so errors can be logged locally.
KHEF_API_URL=http://localhost:5175/api

# Proxy server settings (UI -> proxy -> khef API).
KHEF_PROXY_PORT=5175
KHEF_PROXY_TARGET=http://localhost:3201/api
# Optional: where to write API error logs
# KHEF_PROXY_LOG=../../logs/ui/api-errors.log
