{
  "name": "@khef/ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.2",
  "description": "Web UI for khef knowledge management",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node --watch server/proxy.js & vite",
    "dev:test": "KHEF_USE_TEST_ENV=1 node --watch server/proxy.js & KHEF_USE_TEST_ENV=1 vite --mode test",
    "proxy": "node --watch server/proxy.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "lsof -ti:5176,5177 | xargs kill 2>/dev/null; KHEF_USE_TEST_ENV=1 playwright test; status=$?; node scripts/test-failures.cjs; failures_status=$?; if [ $status -ne 0 ]; then exit $status; fi; exit $failures_status",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:report": "node scripts/test-report.cjs",
    "test:env:up": "./scripts/test-env.sh up",
    "test:env:down": "./scripts/test-env.sh down",
    "test:env:status": "./scripts/test-env.sh status",
    "test:e2e": "KHEF_USE_TEST_ENV=1 playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "cytoscape": "^3.33.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "cytoscape-dagre": "^2.5.0",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "ky": "^1.14.2",
    "lucide-preact": "^0.562.0",
    "mermaid": "^11.12.2",
    "panzoom": "^9.4.3",
    "papaparse": "^5.5.3",
    "preact": "^10.27.2",
    "rehype": "^13.0.2",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "wouter-preact": "^3.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@preact/preset-vite": "^2.10.2",
    "@types/cytoscape": "^3.21.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "autoprefixer": "^10.4.23",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
