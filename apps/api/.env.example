# API Server
PORT=3201
# HOST=127.0.0.1
# CORS_ORIGINS=http://localhost:5174,http://localhost:5173
# RATE_LIMIT_MAX=1000  # requests/minute per IP; 0 to disable

# Database connection (used by both Docker and app)
POSTGRES_USER=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5533
POSTGRES_DB=khef
DATABASE_URL=postgresql://${POSTGRES_USER}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Test database
TEST_POSTGRES_PORT=5435
TEST_POSTGRES_DB=khef_test
TEST_DATABASE_URL=postgresql://${POSTGRES_USER}@${POSTGRES_HOST}:${TEST_POSTGRES_PORT}/${TEST_POSTGRES_DB}

# Optional: Set password for non-trust auth
# POSTGRES_PASSWORD=your_password
# POSTGRES_HOST_AUTH_METHOD=scram-sha-256
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Optional: Override container name
# POSTGRES_CONTAINER=khef

# Kroki diagram rendering service
KROKI_PORT=8101
# KROKI_URL=http://localhost:8100
# Enable Playwright SVG->PNG rasterization for DOCX exports (false to force Kroki PNG).
PNG_RENDERING_ENABLED=true
# Optional: Explicit Chromium path for Playwright if auto-detect fails.
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/Users/you/Library/Caches/ms-playwright/chromium_headless_shell-1208/chrome-headless-shell-mac-arm64/chrome-headless-shell

# Logging
# LOG_DIR=./logs       # Log file directory (default: ./logs)
# LOG_LEVEL=info       # trace, debug, info, warn, error, fatal

# Debug
# DEBUG_GEMINI=true    # Log raw Gemini API responses

# Redis (ephemeral live messaging)
REDIS_PORT=6399
REDIS_URL=redis://localhost:${REDIS_PORT}

# Vector search (semantic similarity via kvec/pgvector)
VECTOR_ENABLED=true

# Push-based session sync (chokidar watcher + Redis pub/sub + SSE)
# When true, a file watcher syncs session JSONL files on each write and
# publishes deltas to SSE subscribers. When false, only the polled
# reconciliation pass (sessions.polledSyncIntervalMinutes) runs.
SESSION_WATCHER_ENABLED=true
