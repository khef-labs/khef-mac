{
  "name": "@khef/api",
  "version": "0.1.0",
  "description": "Khef API server — project memory with PostgreSQL backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "bash scripts/dev-all.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node -r tsx/cjs db/migrate/scripts/migrate.ts && node -r tsx/cjs db/seed/seed.ts",
    "test:db:migrate": "node -r tsx/cjs -e \"require('dotenv-expand').expand(require('dotenv').config()); process.env.DATABASE_URL = process.env.TEST_DATABASE_URL; require('./db/migrate/scripts/migrate')\" && node -r tsx/cjs -e \"require('dotenv-expand').expand(require('dotenv').config()); process.env.DATABASE_URL = process.env.TEST_DATABASE_URL; require('./db/seed/seed')\"",
    "db:migrate:new": "node -r tsx/cjs db/migrate/scripts/create-migration.ts",
    "db:migrate:rollback": "node -r tsx/cjs db/migrate/scripts/rollback.ts",
    "db:migrate:delete": "node -r tsx/cjs db/migrate/scripts/delete-migration.ts",
    "db:migrate:status": "node -r tsx/cjs db/migrate/scripts/migration-status.ts",
    "db:seed": "node -r tsx/cjs db/seed/seed.ts",
    "db:seed:sync": "bash scripts/seed-and-sync.sh",
    "db:backup": "bash db/scripts/backup.sh",
    "db:backup:list": "bash db/scripts/list-backups.sh",
    "db:restore": "bash db/scripts/restore.sh",
    "db:migrate-from-devmem": "bash db/scripts/migrate-from-devmem.sh",
    "test": "mkdir -p test-results && vitest; status=$?; node scripts/test-failures.cjs; failures_status=$?; if [ $status -ne 0 ]; then exit $status; fi; exit $failures_status",
    "test:report": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:migrations": "vitest run tests/migrations",
    "docs:preview": "npm run docs:bundle && python3 -m http.server 8080 & sleep 1 && open http://localhost:8080/docs/api/swagger.html",
    "docs:build": "redocly build-docs docs/api/openapi.yaml -o docs/api/index.html",
    "docs:lint": "redocly lint docs/api/openapi.yaml --config .redocly.yaml",
    "docs:bundle": "redocly bundle docs/api/openapi.yaml -o docs/api/openapi.bundled.yaml",
    "docs:swagger": "open docs/api/swagger.html",
    "sync:user-rules-to-disk": "node scripts/rules/user/index.js",
    "sync:project-rules-to-disk": "node scripts/rules/project/index.js",
    "sync:project-knowledge-to-disk": "node scripts/knowledge/project/index.js",
    "sync:kf-commands-to-disk": "node scripts/prompts/index.js",
    "memory:export": "tsx scripts/memory-export.ts",
    "memory:export:knowledge": "tsx scripts/memory-export.ts --type knowledge",
    "memory:export:rules": "tsx scripts/memory-export.ts --type assistant-rule",
    "memory:import": "tsx scripts/memory-import.ts",
    "rebrand:devmem": "psql $DATABASE_URL -f scripts/rebrand-devmem-to-khef.sql",
    "sessions:sync": "curl -sX POST http://localhost:3201/api/assistants/claude-code/sessions/sync-embeddings > /dev/null & echo 'Sync started. Check status with: npm run sessions:sync:status'",
    "sessions:sync:status": "curl -s http://localhost:3201/api/assistants/claude-code/sessions/sync-embeddings/status | jq",
    "recovery:scan": "tsx scripts/recovery/step1-scan.ts",
    "recovery:plan": "tsx scripts/recovery/step2-plan.ts",
    "recovery:apply": "tsx scripts/recovery/step3-apply.ts",
    "discover:configs": "tsx scripts/discover-configs.ts",
    "mcp:build": "npm --prefix mcp-server run build",
    "mcp:verify": "npm --prefix mcp-server run build && git diff --exit-code -- mcp-server/build",
    "kvec:embed": "tsx scripts/kvec-embed.ts",
    "embed:server": "python3 src/services/vector/embed_server.py",
    "embed:update-model": "python3 scripts/update-embed-model.py",
    "list:tasks": "node ../../scripts/list-tasks.js",
    "kill": "bash scripts/kill.sh"
  },
  "keywords": [
    "memory",
    "api",
    "postgres"
  ],
  "author": "Roger Garza",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "archiver": "^7.0.1",
    "chokidar": "^5.0.0",
    "diff": "^8.0.3",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.7.4",
    "ioredis": "^5.10.0",
    "isolated-vm": "^6.1.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "playwright": "^1.58.0",
    "prom-client": "^15.1.3",
    "undici": "^7.25.0",
    "unique-names-generator": "^4.7.1",
    "zod": "^3.23.8"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.25.3",
    "@types/archiver": "^7.0.0",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.6",
    "@vitest/ui": "^4.0.16",
    "husky": "^9.1.7",
    "swagger-ui-dist": "^5.31.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.0.16"
  }
}
