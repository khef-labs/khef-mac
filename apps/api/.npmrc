# All remaining audit highs trace to GHSA-3ppc-4f35-3m26 (minimatch ReDoS).
# Affected paths are dev/build tools (redocly, archiver, exceljs) that only
# process our own files — no untrusted glob patterns reach these codepaths.
# Transitive minimatch versions (3.x, 5.x, 9.x) can't be overridden to 10.x
# without breaking their consumers. Suppress high-level audit noise.
audit-level=critical
